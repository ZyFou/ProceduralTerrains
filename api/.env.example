NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3001
LOG_LEVEL=info
TRUST_PROXY=false

# Use DATABASE_URL or the individual DB_* settings below.
# DATABASE_URL=mysql://terrain:change-me@127.0.0.1:3306/procedural_terrains
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=procedural_terrains
DB_USER=terrain
DB_PASSWORD=change-me
DB_POOL_SIZE=10

# Comma-separated exact browser origins. Do not use * with cookie sessions.
FRONTEND_ORIGINS=http://localhost:6061

SESSION_COOKIE_NAME=terrain_session
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# Keep empty for a host-only cookie, which is the safest default.
COOKIE_DOMAIN=

# Scrypt work factor. 65536 is a practical production default for this service.
AUTH_SCRYPT_COST=65536

# Exact, comma-separated account emails with protected administrator access.
# Keep this list short. Additional administrators can be promoted in the dashboard.
ADMIN_EMAILS=admin@example.com

# At least 32 random characters in production. Used only for one-way, rotating
# visitor and security identifiers; raw IP addresses are never stored.
PRIVACY_HASH_SECRET=replace-with-a-long-random-production-secret
